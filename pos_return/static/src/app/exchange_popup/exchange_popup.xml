<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_return.ExchangePopup">
        <Dialog title="'Intercambio de Productos'" size="'xl'">
            <div class="exchange-popup p-0 h-100" style="min-height: 420px;">
                <div class="row g-0 h-100">
                    <!-- LEFT COLUMN: Control Panel -->
                    <div class="col-3 exchange-control-panel d-flex flex-column h-100">
                        <div class="p-3 d-flex flex-column h-100">
                            <!-- Exchange Type Selection (Pill Style) -->
                            <div class="mb-3">
                                <div class="exchange-section-label">Tipo de Intercambio</div>
                                <div class="exchange-type-pills">
                                    <button type="button"
                                        t-att-class="'exchange-type-pill' + (state.exchangeType === 'odoo' ? ' active' : '')"
                                        t-on-click="() => { this.state.exchangeType = 'odoo'; this.onTypeChange(); }">
                                        <i class="fa fa-ticket" style="width:16px; text-align:center;"/>
                                        <span>Ticket Odoo</span>
                                    </button>
                                    <button type="button"
                                        t-att-class="'exchange-type-pill' + (state.exchangeType === 'arus' ? ' active' : '')"
                                        t-on-click="() => { this.state.exchangeType = 'arus'; this.onTypeChange(); }">
                                        <i class="fa fa-file-text-o" style="width:16px; text-align:center;"/>
                                        <span>Ticket Arus</span>
                                    </button>
                                    <button type="button"
                                        t-att-class="'exchange-type-pill' + (state.exchangeType === 'no_ticket' ? ' active' : '')"
                                        t-on-click="() => { this.state.exchangeType = 'no_ticket'; this.onTypeChange(); }">
                                        <i class="fa fa-ban" style="width:16px; text-align:center;"/>
                                        <span>No posee Ticket</span>
                                    </button>
                                </div>
                            </div>

                            <!-- Customer Selection -->
                            <div class="mb-3">
                                <div class="exchange-section-label">Cliente</div>
                                <div class="exchange-customer-card d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center text-truncate pe-2">
                                        <div class="exchange-customer-avatar me-2">
                                            <i class="fa fa-user"/>
                                        </div>
                                        <div class="text-truncate">
                                             <t t-if="state.partner">
                                                <div class="fw-bold text-dark text-truncate" style="font-size: 0.82rem;" t-esc="state.partner.name"/>
                                            </t>
                                            <t t-else="">
                                                <span class="text-muted fst-italic" style="font-size: 0.82rem;">Seleccionar...</span>
                                            </t>
                                        </div>
                                    </div>
                                    <button class="btn btn-sm" style="background:#f9f0f6; color:#714B67; border-radius:7px;" t-on-click="selectPartner">
                                        <i class="fa fa-pencil"/>
                                    </button>
                                </div>
                            </div>

                            <!-- Ticket Input -->
                            <div class="mb-3">
                                <div class="exchange-section-label" t-esc="inputLabel"/>
                                
                                <!-- Odoo Ticket Context -->
                                <div t-if="state.exchangeType === 'odoo'">
                                     <div t-if="state.selectedTicket" class="exchange-ticket-card mb-2">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <div class="exchange-ticket-ref" t-esc="state.selectedTicket.pos_reference || state.selectedTicket.name"/>
                                                <div class="d-flex text-muted gap-2 mt-1" style="font-size: 0.72rem;">
                                                    <span><i class="fa fa-calendar me-1"/> <t t-esc="state.selectedTicket.date_order.split(' ')[0]"/></span>
                                                    <span><i class="fa fa-money me-1"/> <t t-esc="env.utils.formatCurrency(state.selectedTicket.available_total)"/></span>
                                                </div>
                                            </div>
                                            <div class="d-flex gap-1">
                                                <button t-if="state.customerTickets.length > 0" class="btn btn-sm" style="background:#f9f0f6; color:#714B67; border-radius:7px;" t-on-click="searchTickets" title="Cambiar Ticket">
                                                    <i class="fa fa-refresh"/>
                                                </button>
                                                <button class="btn btn-sm" style="background:#fef2f2; color:#dc2626; border-radius:7px;" t-on-click="clearSelectedTicket" title="Quitar Ticket">
                                                    <i class="fa fa-times"/>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div t-elif="state.customerTickets.length > 0">
                                        <button class="btn w-100 fw-bold py-2" style="background: linear-gradient(135deg, #714B67 0%, #5a3a52 100%); color:#fff; border-radius:10px; font-size:0.82rem; box-shadow: 0 2px 6px rgba(113,75,103,0.3);" t-on-click="searchTickets">
                                            <i class="fa fa-search me-2"/>Buscar Ticket
                                        </button>
                                    </div>

                                     <div t-elif="state.partner" class="d-flex align-items-center gap-2 p-2 rounded" style="background:#fef3c7; font-size:0.75rem; color:#92400e;">
                                        <i class="fa fa-info-circle"/>
                                        <span>Sin tickets recientes.</span>
                                    </div>
                                </div>

                                <!-- Input Box -->
                                <div class="position-relative">
                                    <t t-if="state.exchangeType === 'odoo' &amp;&amp; !state.selectedTicket">
                                        <!-- Odoo mode: auto-search input -->
                                        <input 
                                            type="text" 
                                            class="form-control"
                                            style="border-radius: 8px; font-size: 0.82rem;"
                                            t-att-value="state.ticket"
                                            t-on-input="onTicketInput"
                                            t-on-focus="onTicketFocus"
                                            t-on-blur="onTicketBlur"
                                            t-att-placeholder="inputPlaceholder"
                                        />
                                        <!-- Search indicator -->
                                        <t t-if="state.searchingTickets">
                                            <div class="text-muted text-center py-1" style="font-size: 0.72rem;">
                                                <i class="fa fa-spinner fa-spin me-1"/>Buscando...
                                            </div>
                                        </t>
                                        <!-- Search Results Dropdown (wider to overflow narrow panel) -->
                                        <t t-if="state.ticketSearchResults.length > 0">
                                            <div class="ticket-search-dropdown" style="position:absolute; left:0; top:100%; z-index:100; background:#fff; border:1px solid #e5e7eb; border-radius:8px; box-shadow:0 4px 16px rgba(0,0,0,0.15); max-height:220px; overflow-y:auto; margin-top:4px; min-width:340px; width:max-content;">
                                                <t t-foreach="state.ticketSearchResults" t-as="result" t-key="result.id">
                                                    <div class="ticket-search-item px-3 py-2"
                                                        style="cursor:pointer; border-bottom:1px solid #f3f4f6; font-size:0.78rem;"
                                                        t-on-click="() => this.selectSearchResult(result)">
                                                        <div class="d-flex justify-content-between align-items-center">
                                                            <div class="fw-bold" style="color:#714B67;" t-esc="result.pos_reference || result.name"/>
                                                            <div class="fw-bold text-nowrap ms-2" style="color:#059669;" t-esc="env.utils.formatCurrency(result.available_total)"/>
                                                        </div>
                                                        <div class="text-muted" style="font-size:0.7rem;">
                                                            <i class="fa fa-calendar me-1"/><t t-esc="result.date_order ? result.date_order.toString().split(' ')[0] : ''"/>
                                                            <span class="ms-2"><i class="fa fa-user me-1"/><t t-esc="result.partner_name || 'Sin cliente'"/></span>
                                                        </div>
                                                    </div>
                                                </t>
                                            </div>
                                        </t>
                                    </t>
                                    <t t-else="">
                                        <!-- Non-Odoo modes or ticket already selected: simple input -->
                                        <input 
                                            type="text" 
                                            class="form-control"
                                            style="border-radius: 8px; font-size: 0.82rem;"
                                            t-model="state.ticket"
                                            t-att-placeholder="inputPlaceholder"
                                            t-att-readonly="state.selectedTicket ? 'readonly' : undefined"
                                            t-att-class="state.selectedTicket ? 'd-none' : ''"
                                        />
                                    </t>
                                </div>
                            </div>

                            <!-- Difference Summary -->
                            <div t-att-class="'exchange-diff-card mt-auto diff-' + differenceType">
                                <div class="exchange-section-label" style="color:inherit; opacity:0.7;">Diferencia</div>
                                <div class="exchange-diff-amount">
                                    <t t-if="differenceType === 'even'">
                                        <i class="fa fa-check-circle me-1"/>
                                        <span>$0.00</span>
                                    </t>
                                    <t t-elif="differenceType === 'charge'">
                                        <i class="fa fa-arrow-up me-1"/>
                                        <span>+<t t-esc="formattedDifference"/></span>
                                    </t>
                                    <t t-else="">
                                        <i class="fa fa-arrow-down me-1"/>
                                        <span>-<t t-esc="formattedDifference"/></span>
                                    </t>
                                </div>
                                <div style="font-size: 0.7rem; opacity: 0.7; margin-top: 2px;" t-esc="differenceLabel"/>
                            </div>
                        </div>
                    </div>

                    <!-- CENTER COLUMN: Products to Return -->
                    <div class="col-products d-flex flex-column h-100 border-end">
                        <div class="column-header-returned">
                            <div class="d-flex align-items-center">
                                <span class="column-header-icon"><i class="fa fa-undo"/></span>
                                <span class="column-header-text">Productos a Devolver</span>
                            </div>
                        </div>

                        <!-- Search for returned products -->
                        <div class="p-2 border-bottom bg-white position-relative" t-if="!state.selectedTicket">
                            <div class="exchange-search-input d-flex align-items-center px-2">
                                <i class="fa fa-search text-muted me-2" style="font-size:0.8rem;"/>
                                <input type="text" class="form-control form-control-sm border-0 ps-0 shadow-none" t-model="state.searchQueryReturned" placeholder="Buscar producto..." style="font-size:0.82rem;"/>
                                <button t-if="isBarcodeScannerSupported()" type="button" class="btn btn-sm p-0 px-1 text-muted" t-on-click="onClickScanReturned">
                                    <i class="fa fa-barcode"/>
                                </button>
                            </div>
                            <!-- Template-based search results -->
                            <div t-if="filteredProductsReturned.length > 0" class="list-group mt-1 border shadow-sm position-absolute w-100 start-0 bg-white" style="max-height: 250px; overflow-y: auto; z-index: 2000; top: 100%; border-radius: 8px;">
                                <t t-foreach="filteredProductsReturned" t-as="tmpl" t-key="tmpl.id">
                                    <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-1 small"
                                        t-on-click="() => this.addReturnedTemplate(tmpl)">
                                        <span class="text-truncate me-2">
                                            <t t-esc="tmpl.name"/>
                                            <span t-if="tmpl.variantCount > 1" class="badge ms-1" style="font-size: 0.65em; background:#f0e4ec; color:#714B67;">
                                                <i class="fa fa-th-list me-1"/><t t-esc="tmpl.variantCount"/> var.
                                            </span>
                                        </span>
                                        <span class="fw-bold text-nowrap"><t t-esc="env.utils.formatCurrency(tmpl.price)"/></span>
                                    </button>
                                </t>
                            </div>
                            <div t-if="state.scanningReturned" class="mt-2 text-center bg-dark p-1 rounded">
                                <ReturnBarcodeScanner onBarcodeScanned.bind="onBarcodeScannedReturned"/>
                            </div>
                        </div>

                        <!-- Returned products list -->
                        <div class="flex-grow-1 overflow-auto p-0">
                            <t t-if="state.returnedProducts.length === 0">
                                <div class="exchange-empty-state d-flex flex-column align-items-center justify-content-center h-100 p-3">
                                    <i class="fa fa-inbox"/>
                                    <span class="text-center">Seleccione un ticket o busque productos a devolver</span>
                                </div>
                            </t>
                            <t t-else="">
                                <table class="exchange-product-table table mb-0">
                                    <thead>
                                        <tr>
                                            <th class="ps-2">Producto</th>
                                            <th class="text-center" style="width: 60px;">Cant.</th>
                                            <th class="text-center" style="width: 80px;">Precio</th>
                                            <th class="text-center" style="width: 60px;">Desc.%</th>
                                            <th class="text-center" style="width: 80px;">Total</th>
                                            <th style="width: 80px;"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.returnedProducts" t-as="product" t-key="product_index">
                                            <tr>
                                                <td class="ps-2">
                                                    <div class="fw-500 text-dark product-name-selectable" style="font-size:0.8rem;" t-esc="product.name"/>
                                                    <span t-if="product.max_quantity" class="max-qty-tag">
                                                        Max: <t t-esc="product.max_quantity"/>
                                                    </span>
                                                </td>
                                                <td class="text-center">
                                                    <input type="number" class="qty-input"
                                                        t-att-value="product.quantity" min="1" step="1"
                                                        t-on-change="(ev) => this.updateReturnedQuantity(product_index, ev.target.value)"/>
                                                </td>
                                                <td class="text-center" style="font-size:0.8rem;" t-esc="env.utils.formatCurrency(product.price_unit)"/>
                                                <td class="text-center">
                                                    <input type="number" class="qty-input"
                                                        t-att-value="product.discount" min="0" max="100" step="1"
                                                        style="width:42px;"
                                                        t-on-input="(ev) => this.updateReturnedDiscount(product_index, ev.target.value)"/>
                                                </td>
                                                <td class="text-center fw-bold" style="font-size:0.8rem;" t-esc="env.utils.formatCurrency(product.quantity * product.price_unit * (1 - (product.discount || 0) / 100))"/>
                                                <td class="exchange-actions-cell text-center">
                                                    <div class="d-flex gap-2 justify-content-center">
                                                        <button t-if="this.hasVariants(product)"
                                                            class="exchange-btn-action exchange-btn-swap"
                                                            t-on-click="() => this.swapVariant(product)"
                                                            title="Cambiar variante (talla/color)">
                                                            <i class="fa fa-retweet"/>
                                                        </button>
                                                        <button class="exchange-btn-action exchange-btn-delete" t-on-click="() => this.removeReturnedProduct(product_index)">
                                                            <i class="fa fa-times"/>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                        </div>
                        <!-- Returned total -->
                        <div class="exchange-total-bar">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="exchange-total-label">Total Devuelto</span>
                                <span class="exchange-total-amount" style="color:#dc2626;" t-esc="formattedReturnTotal"/>
                            </div>
                        </div>
                    </div>

                    <!-- RIGHT COLUMN: New Products -->
                    <div class="col d-flex flex-column h-100">
                        <div class="column-header-new">
                            <div class="d-flex align-items-center">
                                <span class="column-header-icon"><i class="fa fa-shopping-bag"/></span>
                                <span class="column-header-text">Productos Nuevos</span>
                            </div>
                        </div>

                        <!-- Search for new products -->
                        <div class="p-2 border-bottom bg-white position-relative">
                            <div class="exchange-search-input d-flex align-items-center px-2">
                                <i class="fa fa-search text-muted me-2" style="font-size:0.8rem;"/>
                                <input type="text" class="form-control form-control-sm border-0 ps-0 shadow-none" t-model="state.searchQueryNew" placeholder="Buscar producto nuevo..." style="font-size:0.82rem;"/>
                                <button t-if="isBarcodeScannerSupported()" type="button" class="btn btn-sm p-0 px-1 text-muted" t-on-click="onClickScanNew">
                                    <i class="fa fa-barcode"/>
                                </button>
                            </div>
                            <!-- Grouped variant dropdown -->
                            <div t-if="filteredProductsNew.length > 0" class="list-group mt-1 border shadow-sm position-absolute w-100 start-0 bg-white" style="max-height: 250px; overflow-y: auto; z-index: 2000; top: 100%; border-radius: 8px;">
                                <t t-foreach="filteredProductsNew" t-as="tmpl" t-key="tmpl.id">
                                    <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-1 small"
                                        t-on-click="() => this.addNewTemplate(tmpl)">
                                        <span class="text-truncate me-2">
                                            <t t-esc="tmpl.name"/>
                                            <span t-if="tmpl.variantCount > 1" class="badge ms-1" style="font-size: 0.65em; background:#f0e4ec; color:#714B67;">
                                                <i class="fa fa-th-list me-1"/><t t-esc="tmpl.variantCount"/> var.
                                            </span>
                                        </span>
                                        <span class="fw-bold text-nowrap"><t t-esc="env.utils.formatCurrency(tmpl.price)"/></span>
                                    </button>
                                </t>
                            </div>
                            <div t-if="state.scanningNew" class="mt-2 text-center bg-dark p-1 rounded">
                                <ReturnBarcodeScanner onBarcodeScanned.bind="onBarcodeScannedNew"/>
                            </div>
                        </div>

                        <!-- New products list -->
                        <div class="flex-grow-1 overflow-auto p-0">
                            <t t-if="state.newProducts.length === 0">
                                <div class="exchange-empty-state d-flex flex-column align-items-center justify-content-center h-100 p-3">
                                    <i class="fa fa-shopping-cart"/>
                                    <span class="text-center">Busque los productos nuevos que el cliente se lleva</span>
                                </div>
                            </t>
                            <t t-else="">
                                <table class="exchange-product-table table mb-0">
                                    <thead>
                                        <tr>
                                            <th class="ps-2">Producto</th>
                                            <th class="text-center" style="width: 60px;">Cant.</th>
                                            <th class="text-center" style="width: 80px;">Precio</th>
                                            <th class="text-center" style="width: 60px;">Desc.%</th>
                                            <th class="text-center" style="width: 80px;">Total</th>
                                            <th style="width: 36px;"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.newProducts" t-as="product" t-key="product_index">
                                            <tr>
                                                <td class="ps-2">
                                                    <div class="fw-500 text-dark product-name-selectable" style="font-size:0.8rem;" t-esc="product.name"/>
                                                </td>
                                                <td class="text-center">
                                                    <input type="number" class="qty-input"
                                                        t-att-value="product.quantity" min="1" step="1"
                                                        t-on-change="(ev) => this.updateNewQuantity(product_index, ev.target.value)"/>
                                                </td>
                                                <td class="text-center" style="font-size:0.8rem;" t-esc="env.utils.formatCurrency(product.price_unit)"/>
                                                <td class="text-center">
                                                    <input type="number" class="qty-input"
                                                        t-att-value="product.discount" min="0" max="100" step="1"
                                                        style="width:42px;"
                                                        t-on-input="(ev) => this.updateNewDiscount(product_index, ev.target.value)"/>
                                                </td>
                                                <td class="text-center fw-bold" style="font-size:0.8rem;" t-esc="env.utils.formatCurrency(product.quantity * product.price_unit * (1 - (product.discount || 0) / 100))"/>
                                                <td class="text-center">
                                                    <button class="exchange-btn-action exchange-btn-delete" t-on-click="() => this.removeNewProduct(product_index)">
                                                        <i class="fa fa-times"/>
                                                    </button>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                        </div>
                        <!-- New total -->
                        <div class="exchange-total-bar">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="exchange-total-label">Total Nuevo</span>
                                <span class="exchange-total-amount" style="color:#16a34a;" t-esc="formattedNewTotal"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Dialog Footer -->
            <t t-set-slot="footer">
                <div class="exchange-popup-footer d-flex justify-content-between w-100 align-items-center">
                    <div class="d-flex gap-2">
                        <button type="button" class="exchange-btn-cancel" t-on-click="cancel">
                            Cancelar
                        </button>
                        <button type="button" class="exchange-btn-return" t-on-click="switchToReturn">
                            <i class="fa fa-arrow-left me-1"/>Devolución
                        </button>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <!-- Inline difference indicator in footer -->
                        <div t-att-class="'exchange-footer-badge diff-' + differenceType">
                            <t t-if="differenceType === 'even'">
                                <i class="fa fa-check-circle"/>Sin diferencia
                            </t>
                            <t t-elif="differenceType === 'charge'">
                                <i class="fa fa-arrow-up"/>Cobro: <t t-esc="formattedDifference"/>
                            </t>
                            <t t-else="">
                                <i class="fa fa-arrow-down"/>Devolver: <t t-esc="formattedDifference"/>
                            </t>
                        </div>
                        <button type="button" class="exchange-btn-confirm" t-att-disabled="!isValidExchange()" t-on-click="confirm">
                            <i class="fa fa-exchange me-2"/>Confirmar Intercambio
                        </button>
                    </div>
                </div>
            </t>
        </Dialog>
    </t>

</templates>
