<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_return.ExchangeButton">
        <button class="control-button btn btn-secondary btn-lg py-5" t-on-click="click">
            <i class="fa fa-retweet me-1" role="img" aria-label="Intercambio" title="Intercambio" />
            <span>Intercambio</span>
        </button>
    </t>

    <!-- Add Intercambio button to the ReturnPopup footer -->
    <t t-name="pos_return.ReturnPopupExchangeExtend" t-inherit="pos_return.ReturnPopup" t-inherit-mode="extension">
        <xpath expr="//button[@t-on-click='confirm']" position="before">
            <button type="button" class="exchange-btn-action" t-on-click="switchToExchange"
                style="width:auto; height:auto; padding:8px 16px; border-radius:8px; background:#eff6ff; color:#3b82f6; font-weight:600; font-size:0.82rem; border:1.5px solid #bfdbfe;">
                <i class="fa fa-retweet me-2"/>Intercambio
            </button>
        </xpath>
    </t>

</templates>
