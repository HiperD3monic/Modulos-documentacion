<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mrp_production_forecast.ForecastResultCard">
        <div class="pf-result-card-wrapper">
            <!-- Card principal de resultado -->
            <div t-attf-class="pf-result-card {{ resultClass }}">
                <div class="pf-result-icon">
                    <i t-attf-class="fa {{ resultIcon }}"/>
                </div>
                <div class="pf-result-label">
                    Cantidad Máxima Fabricable
                </div>
                <div class="pf-result-number">
                    <t t-esc="formatNumber(props.maxProducible || 0)"/>
                </div>
                <div t-if="props.product" class="pf-result-product">
                    Unidades de <strong><t t-esc="props.product.name"/></strong>
                </div>
                <div class="pf-result-mode mt-1">
                    <span t-if="props.product and props.product.default_code" class="me-2">
                        Código: [<t t-esc="props.product.default_code"/>]
                    </span>
                    <i class="fa fa-filter me-1"/>
                    Modo: <t t-esc="props.modeLabel"/>
                </div>
            </div>

            <!-- Stock actual del producto terminado -->
            <div t-if="props.product" class="pf-stock-info-card mt-3">
                <div class="pf-stock-info-header">
                    <i class="fa fa-archive me-2"/>
                    Stock Actual del Producto
                </div>
                <div class="pf-stock-info-body">
                    <div class="pf-stock-info-row">
                        <div class="pf-stock-info-item">
                            <span class="pf-stock-info-label">En Mano</span>
                            <span class="pf-stock-info-value">
                                <t t-esc="formatNumber(props.product.qty_available || 0)"/>
                            </span>
                            <span class="pf-stock-info-uom"><t t-esc="props.product.uom"/></span>
                        </div>
                        <div class="pf-stock-info-divider"/>
                        <div class="pf-stock-info-item">
                            <span class="pf-stock-info-label">Pronosticado</span>
                            <span class="pf-stock-info-value">
                                <t t-esc="formatNumber(props.product.virtual_available || 0)"/>
                            </span>
                            <span class="pf-stock-info-uom"><t t-esc="props.product.uom"/></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Componente limitante -->
            <div t-if="props.limitingComponent" class="pf-limiting-card mt-3">
                <div class="pf-limiting-header">
                    <i class="fa fa-exclamation-triangle me-2 text-danger"/>
                    Componente Limitante
                </div>
                <div class="pf-limiting-body">
                    <div class="pf-limiting-name">
                        <t t-esc="props.limitingComponent.name"/>
                    </div>
                    <div class="pf-limiting-detail">
                        Permite fabricar solo
                        <strong><t t-esc="formatNumber(props.limitingComponent.producible_qty)"/></strong>
                        unidades
                    </div>
                </div>
            </div>

            <!-- Resumen de estado -->
            <div class="pf-status-summary mt-3">
                <div class="pf-summary-header">
                    <i class="fa fa-bar-chart me-2"/>
                    Resumen de Componentes
                </div>
                <div class="pf-summary-body">
                    <div class="pf-summary-item">
                        <span class="pf-summary-dot pf-dot-green"/>
                        <span class="pf-summary-label">Suficiente</span>
                        <span class="pf-summary-value"><t t-esc="greenCount"/></span>
                    </div>
                    <div class="pf-summary-item">
                        <span class="pf-summary-dot pf-dot-yellow"/>
                        <span class="pf-summary-label">Justo</span>
                        <span class="pf-summary-value"><t t-esc="yellowCount"/></span>
                    </div>
                    <div class="pf-summary-item">
                        <span class="pf-summary-dot pf-dot-red"/>
                        <span class="pf-summary-label">Limitante</span>
                        <span class="pf-summary-value"><t t-esc="redCount"/></span>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>
