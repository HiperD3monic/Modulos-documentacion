<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mrp_production_forecast.ForecastIntermediatesSection">
        <div class="pf-intermediates-card mt-3">
            <div class="pf-intermediates-header" t-on-click="props.toggleExpand">
                <h6 class="mb-0 d-flex align-items-center">
                    <i t-attf-class="fa fa-chevron-{{ props.isExpanded ? 'up' : 'down' }} me-2 pf-collapse-icon"/>
                    <i class="fa fa-sitemap me-2 text-info"/>
                    Productos Intermedios en Stock
                    <span class="pf-intermediate-count ms-2">
                        (<t t-esc="props.intermediates.length"/>)
                    </span>
                </h6>
                <small class="text-muted">
                    Estos productos tienen stock pero no afectan el cálculo principal
                </small>
            </div>
            <div t-if="props.isExpanded" class="pf-intermediates-body">
                <table class="table pf-intermediates-table mb-0">
                    <thead>
                        <tr>
                            <th class="pf-th">Producto Intermedio</th>
                            <th class="pf-th">BoM</th>
                            <th class="pf-th text-center">Cant. por Unidad</th>
                            <th class="pf-th text-center">En Stock</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="props.intermediates" t-as="inter" t-key="inter.id"
                            class="pf-inter-row">
                            <td class="pf-td">
                                <span class="pf-comp-name pf-clickable-product"
                                      t-on-click="() => this.onClickProduct(inter.id)"
                                      title="Abrir producto">
                                    <i class="fa fa-external-link-square me-1 pf-link-icon"/>
                                    <t t-esc="inter.name"/>
                                </span>
                                <small t-if="inter.default_code" class="text-muted ms-1">
                                    [<t t-esc="inter.default_code"/>]
                                </small>
                            </td>
                            <td class="pf-td">
                                <small class="text-muted"><t t-esc="inter.bom_name"/></small>
                            </td>
                            <td class="pf-td text-center">
                                <t t-esc="formatNumber(inter.qty_required)"/>
                                <small class="text-muted ms-1"><t t-esc="inter.uom"/></small>
                            </td>
                            <td class="pf-td text-center">
                                <span t-attf-class="{{ inter.available_qty > 0 ? 'text-success fw-bold' : 'text-muted' }}">
                                    <t t-esc="formatNumber(inter.available_qty)"/>
                                </span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </t>

</templates>
