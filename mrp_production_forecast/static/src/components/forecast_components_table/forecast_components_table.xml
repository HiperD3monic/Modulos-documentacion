<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mrp_production_forecast.ForecastComponentsTable">
        <div class="pf-components-card">
            <div class="pf-card-header">
                <h5 class="mb-0">
                    <i class="fa fa-cubes me-2"/>Componentes Base
                    <span t-if="props.components.length" class="pf-component-count">
                        (<t t-esc="props.components.length"/>)
                    </span>
                </h5>
            </div>
            <div class="pf-card-body p-0">
                <div t-if="!props.components.length" class="text-center text-muted py-4">
                    <i class="fa fa-info-circle me-1"/>
                    No se encontraron componentes base.
                </div>
                <table t-if="props.components.length" class="table pf-components-table mb-0">
                    <thead>
                        <tr>
                            <th class="pf-th">Componente</th>
                            <th class="pf-th text-center">Cant. por Unidad</th>
                            <th class="pf-th text-center"><t t-esc="modeColumnLabel"/></th>
                            <th class="pf-th text-center">Uds. Producibles</th>
                            <th class="pf-th text-center">Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="props.components" t-as="comp" t-key="comp.id"
                            t-attf-class="pf-comp-row pf-comp-row-{{ comp.status }}">
                            <td class="pf-td">
                                <div class="pf-comp-name pf-clickable-product"
                                     t-on-click="() => this.onClickComponent(comp.id)"
                                     title="Abrir producto">
                                    <i class="fa fa-external-link-square me-1 pf-link-icon"/>
                                    <t t-esc="comp.name"/>
                                </div>
                                <small t-if="comp.default_code" class="text-muted">
                                    [<t t-esc="comp.default_code"/>]
                                </small>
                            </td>
                            <td class="pf-td text-center">
                                <span class="pf-number"><t t-esc="formatNumber(comp.qty_required)"/></span>
                                <small class="text-muted ms-1"><t t-esc="comp.uom"/></small>
                            </td>
                            <td class="pf-td text-center">
                                <span class="pf-number"><t t-esc="formatNumber(comp.available_qty)"/></span>
                            </td>
                            <td class="pf-td text-center">
                                <span class="pf-producible-number fw-bold">
                                    <t t-esc="formatNumber(comp.producible_qty)"/>
                                </span>
                            </td>
                            <td class="pf-td text-center">
                                <span t-attf-class="badge pf-status-badge {{ getStatusBadgeClass(comp.status) }}">
                                    <i t-attf-class="fa {{ getStatusIcon(comp.status) }} me-1"/>
                                    <t t-esc="getStatusLabel(comp.status)"/>
                                </span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </t>

</templates>
