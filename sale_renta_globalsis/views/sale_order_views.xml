<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Inherit sale.order form view to add rental_days field         -->
    <!-- ============================================================ -->
    <record id="view_order_form_inherit_rental" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.rental</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- 1. Add "Días de renta" field in order header, after payment_term_id INSIDE group named 'order_details' -->
            <xpath expr="//group[@name='order_details']/field[@name='payment_term_id']" position="after">
                <field name="rental_days"/>
            </xpath>

            <!-- 2. Add "Días de renta" column in sale order line tree (after quantity) -->
            <xpath expr="//field[@name='order_line']//list//field[@name='product_uom_qty']" position="after">
                <field name="rental_days" string="Días de renta" readonly="1" optional="show"/>
            </xpath>

            <!-- 3. Add "Días de renta" in sale order line form (after ordered_qty div) -->
            <xpath expr="//field[@name='order_line']//form//div[@name='ordered_qty']" position="after">
                <label for="rental_days"/>
                <div>
                    <field name="rental_days" class="oe_inline" readonly="1"/>
                </div>
            </xpath>

        </field>
    </record>

</odoo>
