<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Inherit the RENTAL-ONLY form view to add rental_days field   -->
    <!-- This view only loads when accessing orders from the Rental   -->
    <!-- app (Alquiler), not from Sales or Subscriptions.             -->
    <!-- ============================================================ -->
    <record id="view_order_form_inherit_rental" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.rental.days</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_renting.rental_order_primary_form_view"/>
        <field name="arch" type="xml">

            <!-- 1. Add "Días de renta" column in sale order line tree (editable, after quantity) -->
            <xpath expr="//field[@name='order_line']//list//field[@name='product_uom_qty']" position="after">
                <field name="rental_days" string="Periodo de renta" optional="show"/>
            </xpath>

            <!-- 2. Add "Días de renta" in sale order line form (after ordered_qty div) -->
            <xpath expr="//field[@name='order_line']//form//div[@name='ordered_qty']" position="after">
                <label for="rental_days"/>
                <div>
                    <field name="rental_days" class="oe_inline"/>
                </div>
            </xpath>

        </field>
    </record>

</odoo>
